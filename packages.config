<?xml version="1.0" encoding="utf-8"?>
<!--
  NuGet packages for building sentinel.sys in CI.

  Microsoft.Windows.WDK.x64       provides km headers and kernel-mode libs
                                   (ntoskrnl.lib, hal.lib, wdm.lib, …).

  Microsoft.Windows.SDK.CPP        provides platform-independent Windows SDK
                                   headers (shared/sdkddkver.h, shared/basetsd.h, …).

  Microsoft.Windows.SDK.CPP.x64   provides x64 SDK headers and import libs.

  All three must use the same build number (26100.x).  The QFE suffix (.2454,
  .6584, …) may vary; the internal include path is always 10.0.26100.0.
-->
<packages>
  <package id="Microsoft.Windows.SDK.CPP"      version="10.0.26100.6584" targetFramework="native" />
  <package id="Microsoft.Windows.SDK.CPP.x64"  version="10.0.26100.6584" targetFramework="native" />
  <package id="Microsoft.Windows.WDK.x64"      version="10.0.26100.6584" targetFramework="native" />
</packages>
